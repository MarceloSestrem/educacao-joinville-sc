<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id=")?mf,i1QCA}4ITIdR+lS" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="M2FAkZU@mQ]/EMaX%+!@"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace Educacao_Joinville {" line1="}" numlines="2"></mutation><next><block type="typescript_statement" id="TR=`@.~h.DCIs{`,qVE3"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_LCD {" line1="" line2="    let endereco = 0x27" line3="" line4="    function cmd(valor: number) {" line5="        pins.i2cWriteNumber(endereco, valor, NumberFormat.UInt8BE)" line6="        basic.pause(5)" line7="    }" line8="" line9="    //% block=&quot;iniciar LCD&quot;" line10="    //% group=&quot;LCD&quot;" line11="    export function iniciar() {" line12="        cmd(0x38)" line13="        cmd(0x0C)" line14="        cmd(0x06)" line15="        limpar()" line16="    }" line17="" line18="    //% block=&quot;limpar LCD&quot;" line19="    //% group=&quot;LCD&quot;" line20="    export function limpar() {" line21="        cmd(0x01)" line22="        basic.pause(5)" line23="    }" line24="" line25="    //% block=&quot;mostrar %texto na linha %linha coluna %coluna&quot;" line26="    //% group=&quot;LCD&quot;" line27="    export function mostrar(texto: string, linha: number, coluna: number) {" line28="        let pos = linha == 1 ? 0x80 + coluna : 0xC0 + coluna" line29="        cmd(pos)" line30="        for (let i = 0; i &lt; texto.length; i++) {" line31="            pins.i2cWriteNumber(endereco, texto.charCodeAt(i), NumberFormat.UInt8BE)" line32="        }" line33="    }" line34="}" numlines="35"></mutation><next><block type="typescript_statement" id="$Pny~nxP[Wj:p=oFk#Wp"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_Motores {" line1="" line2="    let m1a = AnalogPin.P0" line3="    let m1b = AnalogPin.P1" line4="    let m2a = AnalogPin.P2" line5="    let m2b = AnalogPin.P8" line6="" line7="    function motor(pin1: AnalogPin, pin2: AnalogPin, vel: number) {" line8="        if (vel &gt;= 0) {" line9="            pins.analogWritePin(pin1, vel * 10)" line10="            pins.analogWritePin(pin2, 0)" line11="        } else {" line12="            pins.analogWritePin(pin1, 0)" line13="            pins.analogWritePin(pin2, -vel * 10)" line14="        }" line15="    }" line16="" line17="    //% block=&quot;frente velocidade %vel&quot;" line18="    export function frente(vel: number) {" line19="        motor(m1a, m1b, vel)" line20="        motor(m2a, m2b, vel)" line21="    }" line22="" line23="    //% block=&quot;ré velocidade %vel&quot;" line24="    export function tras(vel: number) {" line25="        motor(m1a, m1b, -vel)" line26="        motor(m2a, m2b, -vel)" line27="    }" line28="" line29="    //% block=&quot;esquerda velocidade %vel&quot;" line30="    export function esquerda(vel: number) {" line31="        motor(m1a, m1b, -vel)" line32="        motor(m2a, m2b, vel)" line33="    }" line34="" line35="    //% block=&quot;direita velocidade %vel&quot;" line36="    export function direita(vel: number) {" line37="        motor(m1a, m1b, vel)" line38="        motor(m2a, m2b, -vel)" line39="    }" line40="" line41="    //% block=&quot;parar motores&quot;" line42="    export function parar() {" line43="        motor(m1a, m1b, 0)" line44="        motor(m2a, m2b, 0)" line45="    }" line46="}" numlines="47"></mutation><next><block type="typescript_statement" id="}paRR#4s2$gj[w1G0rb4"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_Linha {" line1="" line2="    //% block=&quot;seguir linha esq %esq dir %dir&quot;" line3="    export function seguirLinha(esq: DigitalPin, dir: DigitalPin) {" line4="" line5="        let esquerda = pins.digitalReadPin(esq)" line6="        let direita = pins.digitalReadPin(dir)" line7="" line8="        if (esquerda == 0 &amp;&amp; direita == 0) {" line9="            EJ_Motores.frente(80)" line10="        } else if (esquerda == 0 &amp;&amp; direita == 1) {" line11="            EJ_Motores.esquerda(70)" line12="        } else if (esquerda == 1 &amp;&amp; direita == 0) {" line13="            EJ_Motores.direita(70)" line14="        } else {" line15="            EJ_Motores.parar()" line16="        }" line17="    }" line18="}" numlines="19"></mutation><next><block type="typescript_statement" id="V[i93Im/Z[K71a#_^Dp!"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_Distancia {" line1="" line2="    //% block=&quot;distância trig %trig echo %echo (cm)&quot;" line3="    export function distancia(trig: DigitalPin, echo: DigitalPin): number {" line4="" line5="        pins.digitalWritePin(trig, 0)" line6="        control.waitMicros(2)" line7="" line8="        pins.digitalWritePin(trig, 1)" line9="        control.waitMicros(10)" line10="        pins.digitalWritePin(trig, 0)" line11="" line12="        let d = pins.pulseIn(echo, PulseValue.High, 500 * 58)" line13="" line14="        return Math.round(d / 58)" line15="    }" line16="}" numlines="17"></mutation><next><block type="typescript_statement" id="?wz)1}.aG=lo.Y4!^);~"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_SensoresAnalogicos {" line1="" line2="    //% block=&quot;luz %pin&quot;" line3="    export function luz(pin: AnalogPin): number {" line4="        return pins.map(pins.analogReadPin(pin), 0, 1023, 0, 100)" line5="    }" line6="" line7="    //% block=&quot;umidade solo %pin&quot;" line8="    export function solo(pin: AnalogPin): number {" line9="        return pins.map(pins.analogReadPin(pin), 0, 1023, 0, 100)" line10="    }" line11="}" numlines="12"></mutation><next><block type="typescript_statement" id="I5asMCu)-AB3jz,#*w*c"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_SensoresDigitais {" line1="" line2="    //% block=&quot;toque %pin&quot;" line3="    export function toque(pin: DigitalPin): number {" line4="        return pins.digitalReadPin(pin)" line5="    }" line6="" line7="    //% block=&quot;vibração %pin&quot;" line8="    export function vibracao(pin: DigitalPin): number {" line9="        return pins.digitalReadPin(pin)" line10="    }" line11="}" numlines="12"></mutation><next><block type="typescript_statement" id="WQm;Rz[BiD|K/S#gM:KZ"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_Ambiente {" line1="" line2="    let temp = 0" line3="    let umi = 0" line4="" line5="    //% block=&quot;ler ambiente %pin&quot;" line6="    export function ler(pin: DigitalPin) {" line7="        temp = input.temperature()" line8="        umi = 50" line9="    }" line10="" line11="    //% block=&quot;temperatura&quot;" line12="    export function temperatura(): number {" line13="        return temp" line14="    }" line15="" line16="    //% block=&quot;umidade&quot;" line17="    export function umidade(): number {" line18="        return umi" line19="    }" line20="}" numlines="21"></mutation><next><block type="typescript_statement" id="4;0*UrBiNs3LJu9skvdb"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_Cor {" line1="" line2="    //% block=&quot;detectar cor&quot;" line3="    export function cor(): string {" line4="        let v = input.lightLevel()" line5="" line6="        if (v &lt; 50) return &quot;Preto&quot;" line7="        if (v &lt; 100) return &quot;Azul&quot;" line8="        if (v &lt; 150) return &quot;Verde&quot;" line9="        return &quot;Branco&quot;" line10="    }" line11="}" numlines="12"></mutation><next><block type="typescript_statement" id=":#3+1wv`KPws4`S:nq%/"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_Gestos {" line1="" line2="    //% block=&quot;quando agitar&quot;" line3="    export function aoAgitar(handler: () =&gt; void) {" line4="        input.onGesture(Gesture.Shake, handler)" line5="    }" line6="}" numlines="7"></mutation><next><block type="typescript_statement" id="BpHM2EDse%7aPZ!q@|sF"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_Teclado {" line1="" line2="    //% block=&quot;tecla %pin&quot;" line3="    export function tecla(pin: DigitalPin): number {" line4="        return pins.digitalReadPin(pin)" line5="    }" line6="}" numlines="7"></mutation><next><block type="typescript_statement" id="[JdT8V~LKX`Z]DTBUH@I"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace EJ_NFC {" line1="" line2="    //% block=&quot;ler NFC&quot;" line3="    export function ler(): number {" line4="        return 1" line5="    }" line6="}" numlines="7"></mutation></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>